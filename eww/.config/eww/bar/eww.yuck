(defwindow bar
  :monitor 0
  :windowtype "dock"
  :geometry (geometry
    :x "0%"
    :y "0.5%"
    :width "99.5%"
    :height "3%"
    :anchor "top center")
  :stacking "bg"
  :reserve (struts :side "top" :distance "3.5%")
)
