(defvar eww "eww -c $HOME/.config/eww/bar")

(defwidget launcher []
	(box :orientation "h"
		 :space-evenly "false"
		 :spacing -15
  	(button :class "launcher"
		   	:onclick "scripts/launcher" "󰊠 ")))

(defwidget start []
	(box	:orientation "h"
    :space-evenly "false"
    :valign "start"
    (launcher)
  )
)


